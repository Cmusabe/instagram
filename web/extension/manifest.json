{
  "manifest_version": 3,
  "name": "InstaClean — Instagram Follow Request Cleaner",
  "version": "1.1.25",
  "description": "Annuleer al je pending Instagram follow requests in één klik. Gratis, veilig, en 100% lokaal.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://i.instagram.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://instaclean.nl/*",
      "https://*.instaclean.nl/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["utils/storage.js", "utils/instagram-api.js", "content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://instaclean.nl/*", "http://localhost:3000/*", "http://127.0.0.1:3000/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
